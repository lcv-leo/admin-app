{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admin-app",
  "compatibility_date": "2026-03-23",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "BIGDATA_DB",
      "database_name": "bigdata_db",
      "database_id": "6a71b62e-8ab9-45e6-a867-c0d4e6a56269"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "mainsite-media"
    }
  ],
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  }
}