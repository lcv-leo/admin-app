{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admin-app",
  "compatibility_date": "2026-03-23",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "BIGDATA_DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    },
    {
      "binding": "ASTROLOGO_SOURCE_DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    },
    {
      "binding": "CALC_SOURCE_DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "vars": {
    "MAINSITE_WORKER_API_BASE_URL": "https://mainsite-app.lcv.rio.br",
    "APPHUB_PUBLIC_BASE_URL": "https://apphub.lcv.app.br",
    "ADMINHUB_PUBLIC_BASE_URL": "https://adminhub.lcv.app.br"
  },
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  }
}