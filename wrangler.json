{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admin-app",
  "compatibility_date": "2026-03-23",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "BIGDATA_DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    },
    {
      "binding": "ASTROLOGO_SOURCE_DB",
      "database_name": "oraculo_astrologico_db",
      "database_id": "7474fe8e-a56c-4a13-810a-4ec02133bc14"
    },
    {
      "binding": "CALC_SOURCE_DB",
      "database_name": "calculadora-calc-db",
      "database_id": "db259ea6-5583-4820-b7af-c514485cfc9c"
    }
  ],
  "vars": {
    "ASTROLOGO_ADMIN_API_BASE_URL": "https://admin-astrologo.lcv.app.br",
    "CALC_ADMIN_API_BASE_URL": "https://admin.lcv.app.br",
    "MAINSITE_WORKER_API_BASE_URL": "https://mainsite-app.lcv.rio.br",
    "MTASTS_ADMIN_API_BASE_URL": "https://mtasts-admin.lcv.app.br",
    "APPHUB_PUBLIC_BASE_URL": "https://apphub.lcv.app.br",
    "ADMINHUB_PUBLIC_BASE_URL": "https://adminhub.lcv.app.br"
  },
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  }
}