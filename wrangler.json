{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "admin-app",
  "compatibility_date": "2026-04-06",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "BIGDATA_DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "mainsite-media"
    }
  ],
  "services": [
    {
      "binding": "TLSRPT_MOTOR",
      "service": "tlsrpt-motor"
    },
    {
      "binding": "ADMIN_MOTOR",
      "service": "admin-motor"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "ai": {
    "binding": "AI"
  },
  "placement": {
    "mode": "smart"
  }
}
