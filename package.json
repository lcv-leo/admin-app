{
  "name": "admin-app",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "biome": "biome check .",
    "biome:write": "biome check --write .",
    "test": "vitest run",
    "test:admin-motor": "vitest run --config vitest.admin-motor.config.ts",
    "typecheck:admin-motor": "node scripts/typecheck-admin-motor.mjs",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "preview": "vite preview",
    "format": "biome format --write src",
    "stats": "ANALYZE=true vite build",
    "knip": "knip",
    "prepare": "husky",
    "format:public": "prettier --write \"**/index.html\"",
    "format:public:check": "prettier --check \"**/index.html\""
  },
  "dependencies": {
    "@google/genai": "^2.6.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.100.14",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-character-count": "^3.23.6",
    "@tiptap/extension-code-block-lowlight": "^3.23.6",
    "@tiptap/extension-collaboration": "^3.23.6",
    "@tiptap/extension-color": "^3.23.6",
    "@tiptap/extension-drag-handle": "^3.23.6",
    "@tiptap/extension-drag-handle-react": "^3.23.6",
    "@tiptap/extension-dropcursor": "^3.23.6",
    "@tiptap/extension-focus": "^3.23.6",
    "@tiptap/extension-font-family": "^3.23.6",
    "@tiptap/extension-highlight": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-link": "^3.23.6",
    "@tiptap/extension-mention": "^3.23.6",
    "@tiptap/extension-node-range": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-subscript": "^3.23.6",
    "@tiptap/extension-superscript": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/extension-table-cell": "^3.23.6",
    "@tiptap/extension-table-header": "^3.23.6",
    "@tiptap/extension-table-row": "^3.23.6",
    "@tiptap/extension-task-item": "^3.23.6",
    "@tiptap/extension-task-list": "^3.23.6",
    "@tiptap/extension-text-align": "^3.23.6",
    "@tiptap/extension-text-style": "^3.23.6",
    "@tiptap/extension-typography": "^3.23.6",
    "@tiptap/extension-youtube": "^3.23.6",
    "@tiptap/pm": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@tiptap/suggestion": "^3.23.6",
    "@tiptap/y-tiptap": "^3.0.4",
    "@types/sanitize-html": "^2.16.1",
    "dompurify": "^3.4.6",
    "hono": "^4.12.23",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "marked": "^18.0.4",
    "prosemirror-model": "^1.25.7",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.8",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sanitize-html": "^2.17.4",
    "tiptap-markdown": "^0.9.0",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@cloudflare/workers-types": "^4.20260527.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tanstack/react-query-devtools": "^5.100.14",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.0.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.0.0",
    "knip": "^6.14.2",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "wrangler": "^4.95.0"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "biome format --write",
      "eslint --fix"
    ]
  },
  "overrides": {
    "picomatch": "4.0.4",
    "undici": "6.24.0",
    "vite": "$vite",
    "@xmldom/xmldom": "^0.9.10",
    "ws": "8.20.1"
  }
}
