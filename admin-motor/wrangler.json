{
  "$schema": "../node_modules/wrangler/config-schema.json",
  "name": "admin-motor",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-23",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    }
  },
  "secrets_store_secrets": [
    {
      "binding": "GEMINI_API_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "gemini-api-key"
    },
    {
      "binding": "CLOUDFLARE_PW",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "cloudflare-pw"
    },
    {
      "binding": "CLOUDFLARE_DNS",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "cloudflare-dns"
    },
    {
      "binding": "CF_ACCOUNT_ID",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "cloudflare-account-id"
    },
    {
      "binding": "CLOUDFLARE_CACHE",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "cloudflare-cache"
    },
    {
      "binding": "SUMUP_API_KEY_PRIVATE",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "sumup-api-key-private"
    },
    {
      "binding": "SUMUP_MERCHANT_CODE",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "sumup-merchant-code"
    },
    {
      "binding": "MP_ACCESS_TOKEN",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "mp-access-token"
    },
    {
      "binding": "RESEND_API_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "resend-api-key"
    },
    {
      "binding": "GCP_PROJECT_ID",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "gcp-project-id"
    },
    {
      "binding": "JINA_API_KEY",
      "store_id": "df90c0935ba1460899c3c2c457548a90",
      "secret_name": "jina-api-key"
    }
  ],
  "d1_databases": [
    {
      "binding": "BIGDATA_DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MEDIA_BUCKET",
      "bucket_name": "mainsite-media"
    }
  ],
  "ai": {
    "binding": "AI"
  }
}